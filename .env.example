# TARA Unified Docker Compose Environment Variables
# Copy this file to .env and customize as needed

# Frontend Configuration
# URL path prefix for API requests from the browser (e.g., /backend, /api)
NEXT_PUBLIC_API_BASE_URL=/backend

# Enable the /bootstrap admin page for initial setup (true/false)
NEXT_PUBLIC_ENABLE_BOOTSTRAP_PAGE=false

# Backend API URL for Next.js server-side proxy
# In unified Docker setup, this points to the API service via Docker network
API_PROXY_TARGET=http://api:8000

# Resume parsing backend in Docker
# `auto` tries MinerU first and falls back to native parser.
RESUME_PARSER_BACKEND=mineru
RESUME_PARSER_ALLOW_FALLBACK=false
MINERU_API_BASE_URL=http://mineru-api:8000
MINERU_API_TIMEOUT_SECONDS=300
MINERU_PDF_MAX_PAGES=3
MINERU_PDF_RENDER_SCALE=2.0
HF_HUB_DISABLE_XET=1

# Optional: Pre-set tenant ID for development
# NEXT_PUBLIC_DEFAULT_TENANT_ID=

# Note: Backend environment variables should be configured in TARA - backend/.env.local
# This includes database credentials, Redis settings, secrets, and API keys
