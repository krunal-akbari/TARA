      ]
    },
    {
      "name": "Routing",
      "item": [
        {
          "name": "Create Route Transition",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('route_transition_id', data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "X-Tenant-Id", "value": "{{tenant_id}}" },
              { "key": "Idempotency-Key", "value": "route-{{$timestamp}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"to_node_type\": \"client\",\n  \"to_node_id\": {{client_id}},\n  \"reason\": \"submitted\",\n  \"notes\": \"initial handoff\"\n}"
            },
            "url": "{{base_url}}/api/v1/jobs/{{job_id}}/route-transitions"
          }
        },
        { "name": "List Route Transitions", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "X-Tenant-Id", "value": "{{tenant_id}}" } ], "url": "{{base_url}}/api/v1/jobs/{{job_id}}/route-transitions?page=1&page_size=20" } },
        { "name": "Current Route", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "X-Tenant-Id", "value": "{{tenant_id}}" } ], "url": "{{base_url}}/api/v1/jobs/{{job_id}}/current-route" } }
      ]
    },
    {
