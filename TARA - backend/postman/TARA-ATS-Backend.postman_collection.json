        { "name": "Get Job", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "X-Tenant-Id", "value": "{{tenant_id}}" } ], "url": "{{base_url}}/api/v1/jobs/{{job_id}}" } },
