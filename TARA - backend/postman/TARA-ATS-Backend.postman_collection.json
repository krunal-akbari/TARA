              { "key": "X-Tenant-Id", "value": "{{tenant_id}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": {{client_id}},\n  \"vendor_id\": {{vendor_id}},\n  \"status\": \"active\",\n  \"priority\": 100,\n  \"effective_from\": null,\n  \"effective_to\": null\n}"
            },
            "url": "{{base_url}}/api/v1/client-vendor-links"
          }
        },
        { "name": "List Links", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "X-Tenant-Id", "value": "{{tenant_id}}" } ], "url": "{{base_url}}/api/v1/client-vendor-links?include_deleted=false&page=1&page_size=20" } },
        { "name": "Update Link", "request": { "method": "PATCH", "header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "X-Tenant-Id", "value": "{{tenant_id}}" }, { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"status\": \"inactive\",\n  \"priority\": 10\n}" }, "url": "{{base_url}}/api/v1/client-vendor-links/{{link_id}}" } },
        { "name": "Delete Link", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "X-Tenant-Id", "value": "{{tenant_id}}" } ], "url": "{{base_url}}/api/v1/client-vendor-links/{{link_id}}" } },
        { "name": "Restore Link", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "X-Tenant-Id", "value": "{{tenant_id}}" } ], "url": "{{base_url}}/api/v1/client-vendor-links/{{link_id}}/restore" } }
      ]
    },
