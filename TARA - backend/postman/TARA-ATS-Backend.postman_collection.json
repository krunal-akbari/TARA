{
  "info": {
    "name": "TARA ATS Backend",
    "description": "Module-wise API collection for TARA ATS backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Live",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health/live"
          }
        },
        {
          "name": "Ready",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health/ready"
          }
        }
      ]
    },
    {
      "name": "Tenancy",
      "item": [
        {
          "name": "Bootstrap Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('tenant_id', data.tenant_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Bootstrap-Key", "value": "{{bootstrap_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_name\": \"{{tenant_name}}\",\n  \"admin_email\": \"{{admin_email}}\",\n  \"admin_password\": \"{{admin_password}}\",\n  \"currency_code\": \"USD\",\n  \"timezone\": \"UTC\",\n  \"resume_retention_days\": 365,\n  \"audit_retention_days\": 730\n}"
            },
            "url": "{{base_url}}/api/v1/admin/tenants/bootstrap"
          }
        },
        {
          "name": "Public Onboarding",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('tenant_id', data.tenant_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Onboarding-Key", "value": "{{onboarding_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenant_name\": \"{{tenant_name}}\",\n  \"admin_email\": \"{{admin_email}}\",\n  \"admin_password\": \"{{admin_password}}\",\n  \"currency_code\": \"USD\",\n  \"timezone\": \"UTC\",\n  \"resume_retention_days\": 365,\n  \"audit_retention_days\": 730\n}"
            },
            "url": "{{base_url}}/api/v1/public/onboarding"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('access_token', data.access_token);",
                  "  pm.environment.set('refresh_token', data.refresh_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/login"
          }
        },
        {
          "name": "Refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('access_token', data.access_token);",
                  "  pm.environment.set('refresh_token', data.refresh_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/api/v1/auth/logout"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "X-Tenant-Id", "value": "{{tenant_id}}" }
            ],
            "url": "{{base_url}}/api/v1/auth/me"
          }
        }
      ]
    },
    {
      "name": "Clients",
      "item": [
        {
          "name": "Create Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('client_id', data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "X-Tenant-Id", "value": "{{tenant_id}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Client A\",\n  \"status\": \"active\"\n}" },
            "url": "{{base_url}}/api/v1/clients"
          }
        },
        { "name": "List Clients", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "X-Tenant-Id", "value": "{{tenant_id}}" } ], "url": "{{base_url}}/api/v1/clients?include_deleted=false&page=1&page_size=20" } },
        { "name": "Get Client", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "X-Tenant-Id", "value": "{{tenant_id}}" } ], "url": "{{base_url}}/api/v1/clients/{{client_id}}" } },
        { "name": "Update Client", "request": { "method": "PATCH", "header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "X-Tenant-Id", "value": "{{tenant_id}}" }, { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Client A Updated\"\n}" }, "url": "{{base_url}}/api/v1/clients/{{client_id}}" } },
        { "name": "Delete Client", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "X-Tenant-Id", "value": "{{tenant_id}}" } ], "url": "{{base_url}}/api/v1/clients/{{client_id}}" } },
        { "name": "Restore Client", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "X-Tenant-Id", "value": "{{tenant_id}}" } ], "url": "{{base_url}}/api/v1/clients/{{client_id}}/restore" } }
      ]
    },
    {
      "name": "Vendors",
      "item": [
        {
          "name": "Create Vendor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('vendor_id', data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "X-Tenant-Id", "value": "{{tenant_id}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Vendor X\",\n  \"status\": \"active\",\n  \"client_id\": {{client_id}}\n}" },
            "url": "{{base_url}}/api/v1/vendors"
          }
        },
        { "name": "List Vendors", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "X-Tenant-Id", "value": "{{tenant_id}}" } ], "url": "{{base_url}}/api/v1/vendors?include_deleted=false&page=1&page_size=20" } },
        { "name": "Get Vendor", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "X-Tenant-Id", "value": "{{tenant_id}}" } ], "url": "{{base_url}}/api/v1/vendors/{{vendor_id}}" } },
        { "name": "Update Vendor", "request": { "method": "PATCH", "header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "X-Tenant-Id", "value": "{{tenant_id}}" }, { "key": "Content-Type", "value": "application/json" } ], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Vendor X Updated\"\n}" }, "url": "{{base_url}}/api/v1/vendors/{{vendor_id}}" } },
        { "name": "Delete Vendor", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "X-Tenant-Id", "value": "{{tenant_id}}" } ], "url": "{{base_url}}/api/v1/vendors/{{vendor_id}}" } },
        { "name": "Restore Vendor", "request": { "method": "POST", "header": [ { "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "X-Tenant-Id", "value": "{{tenant_id}}" } ], "url": "{{base_url}}/api/v1/vendors/{{vendor_id}}/restore" } }
      ]
    },
