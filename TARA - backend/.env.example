APP_NAME=TARA ATS Backend
ENV=local
DEBUG=true
DATABASE_URL=sqlite:///./tara.db
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
MAX_RESUME_UPLOAD_MB=10
RESUME_RETENTION_DAYS=365
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
JWT_SECRET_KEY=REPLACE_ME_WITH_STRONG_SECRET
JWT_ALGORITHM=HS256
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage
AWS_REGION=us-east-1
AWS_S3_BUCKET=tara-resumes
BOOTSTRAP_API_KEY=REPLACE_ME_WITH_STRONG_SECRET
PUBLIC_ONBOARDING_KEYS=nalashaa,nalashaa2
PUBLIC_ONBOARDING_ALLOWED_EMAILS=admin@example.com,public-admin@example.com
AUTO_CREATE_TABLES=true
